{
  "env": {
    "node": true,
    "browser": true,
    "es6": true
  },
  "globals": {
    "app": "readonly",
    "io": "readonly",
    "ApiClient": "readonly",
    "Download": "readonly",
    "Paginate": "readonly",
    "Mixed": "readonly",
    "Crontab": "readonly",
    "Encrypter": "readonly",
    "Filter": "readonly",
    "i18n": "readonly",
    "Jwt": "readonly",
    "VSError": "readonly",
    "ABS_PATH": "readonly",
    "APP_PATH": "readonly",
    "CORE_PATH": "readonly",
    "PUBLIC_PATH": "readonly"
  },
  "rules": {
    "curly": "error",
    "no-console": "off",
    "no-underscore-dangle": "off",
    "no-throw-literal": "off",
    "no-unneeded-ternary": "off",
    "guard-for-in": "off"
  },
  "ignorePatterns": [
    "node_modules",
    "test",
    "bundle",
    "tasks",
    "docs",
    "public",
    "setup"
  ]
}
